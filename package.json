{
  "name": "mermaid-architecture",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "build:worker": "wrangler deploy --dry-run --outdir=dist/worker",
    "deploy": "vite build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply mermaid-arch-db --local",
    "db:migrate": "wrangler d1 migrations apply mermaid-arch-db --remote",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-all": "tsc --noEmit && biome check ."
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "hono": "^4.7.0",
    "lib0": "^0.2.117",
    "nanoid": "^5.1.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.2",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/workers-types": "^4.20250424.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.14.0"
  }
}
